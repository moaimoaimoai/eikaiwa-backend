# 32バイト以上のランダムな文字列を設定（生成: python3 -c "import secrets; print(secrets.token_urlsafe(50))"）
SECRET_KEY=your-very-long-secret-key-at-least-32-chars-here

DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DATABASE_URL=sqlite:///db.sqlite3
OPENAI_API_KEY=your-openai-api-key-here
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://192.168.1.13:8081

# ── 開発・TestFlight用 ──
# True: 全ユーザーをプレミアム扱い（支払い不要でフル機能テスト可能）
# False（本番）: subscription_tier と subscription_expires_at で判定
BYPASS_SUBSCRIPTION=True
