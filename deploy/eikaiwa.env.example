# EC2 上の環境変数ファイル
# このファイルを /etc/eikaiwa.env としてコピーし、値を実際のものに変更する
# sudo cp eikaiwa.env.example /etc/eikaiwa.env
# sudo chmod 600 /etc/eikaiwa.env

SECRET_KEY=your-very-long-random-secret-key-here
DEBUG=False
ALLOWED_HOSTS=api.your-domain.com,your-cloudfront-id.cloudfront.net
DATABASE_URL=postgresql://user:password@your-rds-endpoint:5432/eikaiwa
OPENAI_API_KEY=sk-xxxxxxxxxxxx
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://your-cloudfront-id.cloudfront.net
